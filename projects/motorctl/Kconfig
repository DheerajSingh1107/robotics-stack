config EXAMPLES_MOTORCTL
    tristate "Motor control example"
    default n
    ---help---
        Enable the motor control example application.

config EXAMPLES_MOTORCTL_PROGNAME
    string "Program name"
    depends on EXAMPLES_MOTORCTL
    default "motorctl"

config EXAMPLES_MOTORCTL_PRIORITY
    int "Task priority"
    depends on EXAMPLES_MOTORCTL
    default 100

config EXAMPLES_MOTORCTL_STACKSIZE
    int "Stack size"
    depends on EXAMPLES_MOTORCTL
    default DEFAULT_TASK_STACKSIZE
